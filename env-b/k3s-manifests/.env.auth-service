# K3s Environment Configuration for Auth Service
# Used in: k3s-manifests/deployments/auth-service.yaml

# Database - PostgreSQL di namespace todo-app
DATABASE_URL=postgresql://todouser:todopass@postgres.todo-app.svc.cluster.local:5432/authdb

# Service Port
AUTH_PORT=3003

# JWT Configuration
JWT_SECRET=supersecretkey123
JWT_EXPIRY=24h

# Redis - Redis di namespace todo-app
REDIS_URL=redis://redis.todo-app.svc.cluster.local:6379

# Environment Type
ENVIRONMENT=kubernetes
