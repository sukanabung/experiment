# K3s Environment Configuration - Database Setup
# Used for: PostgreSQL initialization via ConfigMap

# PostgreSQL User
POSTGRES_USER=todouser

# PostgreSQL Password (should be changed in production!)
POSTGRES_PASSWORD=todopass

# PostgreSQL Database (default, will be created)
POSTGRES_DB=authdb

# Redis Configuration
# Redis doesn't use environment variables, but these are for reference
REDIS_HOST=redis.todo-app.svc.cluster.local
REDIS_PORT=6379

# Environment Type
ENVIRONMENT=kubernetes
