# K3s Environment Configuration for Frontend
# Used in: k3s-manifests/deployments/frontend.yaml

# Frontend doesn't need env vars but this is template for reference
# Frontend akan access services via browser yang auto-resolve DNS ke service endpoints

# Note: Frontend HTML/JS files use window.location.hostname untuk dynamic API routing
# di Docker: localhost (port 3003, 3001)
# di K3s: akan access via service names yang di-proxy via Nginx

# Environment Type
ENVIRONMENT=kubernetes
